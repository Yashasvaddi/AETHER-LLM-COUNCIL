# Models appear different in logs but route to 3 unique instances
PRO_MODEL_1=godfather/gpt-oss:20b
PRO_MODEL_2=godfather/gpt-oss:20b
CON_MODEL_1=godfather/gpt-oss:20b
CON_MODEL_2=godfather/gpt-oss:20b
JUDGE_MODEL=godfather/gpt-oss:20b

ENABLE_FALLBACK_MODE=false

# Godfather Endpoint
GODFATHER_ENDPOINT=https://godfatherpersonalcomputer.shop/asklaptop

# Web Search
SEARCH_ENGINE=duckduckgo
MAX_SEARCH_RESULTS=3
MAX_SCRAPED_PAGES_PER_FACTOR=5
SCRAPE_TIMEOUT=15

# Rate Limiting
REQUEST_DELAY_SECONDS=1.0
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=3.0

# Debate
DEBATE_ROUNDS=2
MAX_ARGUMENT_LENGTH=120
ALLOW_CROSS_CRITIQUE=true
MAX_FACTORS=2

# Evaluation
ENABLE_ANONYMIZATION=true
SCORING_SCALE=1-10

# Output
OUTPUT_DIR=outputs/
SAVE_TRANSCRIPTS=true
